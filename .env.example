# Copy to `.env.local` for local dev, or set as build-time env vars / repo secrets.
# Only variables prefixed with VITE_ are exposed to the client bundle.

# Newsletter / release-alert opt-in (Block D — W10/W11).
# A third-party form-service endpoint that accepts a JSON POST of
# { email, consent, source, tags }. Works with Formspree, Buttondown,
# Web3Forms, etc. When unset, the footer signup UI is not rendered.
# In CI this is populated from the NEWSLETTER_ENDPOINT repo secret
# (see .github/workflows/deploy.yml).
VITE_NEWSLETTER_ENDPOINT=
